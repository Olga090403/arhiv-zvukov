# Supabase Management API (только для scripts/seed-sounds.mjs, локально)
# SUPABASE_ACCESS_TOKEN=sbp_...

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Публичный URL сайта (sitemap, og:url, canonical)
# GitHub Pages: https://olga090403.github.io/arhiv-zvukov
# Cloudflare Pages: https://arhiv-zvukov.pages.dev
VITE_SITE_URL=https://arhiv-zvukov.pages.dev

# Cloudflare Pages deploy (scripts/setup-cloudflare-pages.ps1, локально cf:deploy)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# DigitalOcean Spaces — §9.3 (optional, for audio storage)
VITE_DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
VITE_DO_SPACES_BUCKET=your_bucket_name_here
VITE_DO_SPACES_KEY=your_access_key_here
DO_SPACES_SECRET=your_secret_key_here

# AI (после MVP, server-side only)
# OPENAI_API_KEY=your_openai_key_here
# MINIMAX_API_KEY=your_minimax_key_here
