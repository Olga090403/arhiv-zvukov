{
  "expo": {
    "name": "Архив звуков",
    "slug": "arhiv-zvukov",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "arhiv-zvukov",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F1E8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.arhivzvukov.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Для записи звуков в архив",
        "NSLocationWhenInUseUsageDescription": "Для указания места записи звука"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F1E8"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.arhivzvukov.mobile",
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Для записи звуков в архив"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Для указания места записи звука"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F2C94C"
        }
      ]
    ]
  }
}
